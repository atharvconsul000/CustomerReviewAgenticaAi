# Root .gitignore

# Mac OS
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Backend
backend/venv/
backend/.venv/
backend/data/chroma/
backend/data/*.db
backend/data/*.db-*
